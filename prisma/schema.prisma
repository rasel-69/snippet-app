generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Snippet {
  id     Int    @id @default(autoincrement())
  title  String
  code   String
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
}







